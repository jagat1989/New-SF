# Special Fare — Environment variables
# Copy this file to .env and fill in real values.
# On the server, deploy.sh generates .env automatically.

# ─────────────────────────────────────────────────────────────
# DATABASE — choose ONE of the two options below
# ─────────────────────────────────────────────────────────────

# OPTION A — Local SQLite (default, good for dev / small deploys)
# DATABASE_URL=file:/var/www/special-fare/db/custom.db
# (prisma/schema.prisma provider must be "sqlite")

# OPTION B — Supabase / hosted PostgreSQL (recommended for production)
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Your project: iqqaafsyhpwfuucueftz
# Replace YOUR_PASSWORD with your actual database password.
# (If your password has special characters like @, #, /, percent-encode them:
#  e.g. @ → %40, # → %23, / → %2F. Use https://www.urlencoder.org/ if unsure.)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.iqqaafsyhpwfuucueftz.supabase.co:5432/postgres
DATABASE_URL_NON_POOLING=postgresql://postgres:YOUR_PASSWORD@db.iqqaafsyhpwfuucueftz.supabase.co:5432/postgres
# (prisma/schema.prisma provider must be "postgresql")

# ─────────────────────────────────────────────────────────────

# Session signing secret — MUST be a long random string in production.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Runtime environment
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1

# ---- Admin account (used by `npm run seed` / `npx tsx scripts/seed.ts`) ----
# The seed script creates the admin user with these credentials.
# Leave unset to use the demo admin (admin@specialfare.com / password123).
# Set these to your REAL admin email + a strong password on the production server.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_NAME=Your Name


